# ============================================================
# .env.prod — Environnement PRODUCTION
# URL publique : https://eduwinget.ceti.etat-ge.ch
# Copier en .env.prod et compléter les secrets
# ============================================================

# PostgreSQL
POSTGRES_DB=wgrepo
POSTGRES_USER=wgrepo
POSTGRES_PASSWORD=CHANGEZ-MOI

# Dossier sur l'hôte contenant les certificats TLS :
#   /opt/wg-repo/certs/cert.pem  — certificat + chaîne intermédiaire
#   /opt/wg-repo/certs/key.pem   — clé privée
CERTS_DIR=/opt/wg-repo/certs
