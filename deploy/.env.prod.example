# ============================================================
# .env.prod — Environnement PRODUCTION
# URL publique : https://eduwinget.ceti.etat-ge.ch
# Copier en .env.prod et compléter les secrets
# ============================================================

# Registre GitHub Container Registry
REGISTRY=ghcr.io/arnaud-edu-cpu64

# Tag de l'image à déployer (correspond au tag git poussé sur GitHub)
TAG=latest

# PostgreSQL
POSTGRES_DB=wgrepo
POSTGRES_USER=wgrepo
POSTGRES_PASSWORD=CHANGEZ-MOI

# Dossier sur l'hôte contenant les certificats TLS :
#   /opt/wg-repo/certs/cert.pem  — certificat + chaîne intermédiaire
#   /opt/wg-repo/certs/key.pem   — clé privée
CERTS_DIR=/opt/wg-repo/certs

# Authentification LDAP/AD
# Générer un secret fort : openssl rand -hex 32
SESSION_SECRET=CHANGEZ-MOI-SECRET-FORT

# URLs des contrôleurs de domaine (séparées par des virgules)
LDAP_URLS=ldap://ECUREUIL.ge-pedago.etat-ge.ch,ldap://ELEPHANT.ge-pedago.etat-ge.ch,ldap://ENARGIA.ge-pedago.etat-ge.ch

# DN de base Active Directory
LDAP_BASE_DN=DC=ge-pedago,DC=etat-ge,DC=ch

# OU contenant les comptes utilisateurs (ajustez OU=___ selon votre AD)
LDAP_USER_BASE=OU=Utilisateurs,OU=___,DC=ge-pedago,DC=etat-ge,DC=ch

# DN complet du groupe qui autorise l'accès
LDAP_GROUP_DN=CN=GAP-Winget,OU=Groupes,DC=ge-pedago,DC=etat-ge,DC=ch

# Nom NetBIOS du domaine (utilisé pour le bind UPN : user@ge-pedago)
LDAP_DOMAIN=ge-pedago

# Durée de session en heures (défaut: 8h = une journée de travail)
SESSION_MAX_AGE_HOURS=8
