# ============================================================
# .env.example — Variables d'environnement WG-Repo
# Copier ce fichier en .env.prod ou .env.rec et remplir les valeurs
# NE PAS committer les fichiers .env réels (contiennent des secrets)
# ============================================================

# ------------------------------
# Registre Docker
# Chemin de base des images (sans le nom de l'image ni le tag)
#
# GitLab interne (recommandé) :
#   REGISTRY=registry.gitlab.interne/groupe/wg-selfRepo
#
# GitHub Container Registry (si accès internet disponible) :
#   REGISTRY=ghcr.io/Arnaud-cpu64
# ------------------------------
REGISTRY=registry.gitlab.interne/groupe/wg-selfRepo

# Tag de l'image à déployer
#   PROD : utiliser un tag versionné (ex: v1.2.3)
#   REC  : utiliser latest ou un tag de release candidate
TAG=latest

# ------------------------------
# PostgreSQL
# ------------------------------
POSTGRES_DB=wgrepo
POSTGRES_USER=wgrepo
POSTGRES_PASSWORD=CHANGEZ-MOI-EN-PRODUCTION

# ------------------------------
# Réseau
# Port HTTP exposé sur l'hôte
#   PROD : 80
#   REC  : 8080
# ------------------------------
HTTP_PORT=80
