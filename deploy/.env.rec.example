# ============================================================
# .env.rec — Environnement RECETTE
# URL publique : https://eduwinget.rec.etat-ge.ch
# Copier en .env.rec et compléter les secrets
# ============================================================

# Registre GitHub Container Registry
REGISTRY=ghcr.io/arnaud-edu-cpu64

# Tag latest pour la recette
TAG=latest

# PostgreSQL
POSTGRES_DB=wgrepo
POSTGRES_USER=wgrepo
POSTGRES_PASSWORD=CHANGEZ-MOI-REC

# Dossier sur l'hôte contenant les certificats TLS :
#   /opt/wg-repo/certs/cert.pem  — certificat + chaîne intermédiaire
#   /opt/wg-repo/certs/key.pem   — clé privée
CERTS_DIR=/opt/wg-repo/certs

# Authentification LDAP/AD
# URLs des contrôleurs de domaine (séparées par des virgules)
LDAP_URLS=ldap://DC1.domaine,ldap://DC2.domaine

# DN de base Active Directory (remplire)
LDAP_BASE_DN=

# OU contenant les comptes utilisateurs (ajustez OU=___ selon votre AD)
LDAP_USER_BASE=

# DN complet du groupe qui autorise l'accès
LDAP_GROUP_DN=GAP-xxx

# Nom NetBIOS du domaine (utilisé pour le bind UPN : user@domain)
LDAP_DOMAIN=DOMAIN_NAME

# Durée de session en heures (défaut: 8h = une journée de travail)
SESSION_MAX_AGE_HOURS=8
